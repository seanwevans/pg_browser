-- Verify history numbering is sequential
SELECT (
    SELECT n FROM pgb_session.history WHERE session_id = :'sid' ORDER BY n DESC LIMIT 1
) = count(*) AS sequential
FROM pgb_session.history WHERE session_id = :'sid';
